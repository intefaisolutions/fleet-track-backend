# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/fleet_saas

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Super Admin one-time setup
SUPER_ADMIN_SETUP_SECRET=your-setup-secret

# -----------------------------------------------------------------------------
# Email — forgot-password OTP (nodemailer / SMTP)
# Gmail: use App Password — https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=FleetTrack
