# App
NODE_ENV=development
PORT=3000
APP_NAME=FleetTrack
CORS_ORIGIN=http://localhost:5173

# Public API URL (Swagger, callbacks)
APP_BASE_URL=http://localhost:3000

# Admin web app — emails (license register link, password reset page)
# Production: https://fleettrackservice.in  (no trailing slash)
ADMIN_APP_URL=http://localhost:5173

# Optional path overrides (defaults match Fleet-admin routes)
# APP_PATH_SIGN_IN=/signin
# APP_PATH_REGISTER_COMPANY=/register-company
# APP_PATH_FORGOT_PASSWORD=/forgot-password

# Database
MONGODB_URI=mongodb://localhost:27017/fleet_saas

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Super Admin one-time setup
SUPER_ADMIN_SETUP_SECRET=your-setup-secret

# Google Sign-In (OAuth 2.0 Web client ID — same as VITE_GOOGLE_CLIENT_ID on admin)
GOOGLE_CLIENT_ID=

# License: days after validUntil that company users can still log in (default 7)
LICENSE_GRACE_PERIOD_DAYS=7

# -----------------------------------------------------------------------------
# Email — forgot-password OTP, license key, owner/driver welcome (nodemailer / SMTP)
# Gmail: use App Password — https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=FleetTrack
